#!/usr/bin/expect -f

set timeout 15
set repo [lindex $argv 0]
set fakehome [lindex $argv 1]
set stubbin [lindex $argv 2]
set keys [lrange $argv 3 end]

set nocolor "NO_COLOR=1"
if {[info exists env(MENU_COLOR)]} { set nocolor "NO_COLOR=" }

spawn env -i HOME=$fakehome PATH=$stubbin:/usr/bin:/bin TERM=xterm $nocolor /bin/bash $repo/install.sh --skip-deps

expect {
    "enter install" {}
    timeout { exit 99 }
    eof { exit 98 }
}

foreach key $keys {
    after 100
    expect -timeout 0 -re {.+} {}
    switch -- $key {
        ENTER { send "\r" }
        CTRL_C { send "\003" }
        UP { send "\033\[A" }
        DOWN { send "\033\[B" }
        SPACE { send " " }
        ESC { send "\033" }
        PAUSE { after 2000; expect -timeout 0 -re {.+} {} }
        default { send -- $key }
    }
}

expect {
    eof {}
    timeout { exit 99 }
}

catch wait result
exit [lindex $result 3]
